{
  "name": "servhub",
  "version": "1.0.8",
  "description": "ServHub — Linux App Store",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-linux": "electron-builder --linux AppImage deb"
  },
  "build": {
    "appId": "net.servexa.servhub",
    "productName": "ServHub",
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "icon.png",
      "frontend/dist/**/*",
      "package.json"
    ],
    "linux": {
      "category": "System",
      "description": "ServHub — Linux App Store",
      "target": ["AppImage", "deb"],
      "maintainer": "Abdulrahman AlAli (B5aaR)"
    },
    "deb": {
      "depends": ["flatpak", "libnss3", "libatk1.0-0", "libasound2"],
      "priority": "optional"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
