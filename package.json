{
  "name": "servhub",
  "version": "1.0.1",
  "description": "ServHub — Linux App Store",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "net.servexa.servhub",
    "productName": "ServHub",
    "icon": "icon.png",
    "files": [
      "main.js",
      "icon.png",
      "frontend/dist/**/*",
      "backend/**/*",
      "package.json"
    ],
    "linux": {
      "category": "System",
      "description": "ServHub — Linux App Store",
      "target": ["AppImage"]
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
